# Normalize line endings to LF on commit, checkout as-is
* text=auto

# Python files — always LF
*.py text eol=lf

# Config and docs — always LF
*.txt  text eol=lf
*.md   text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.cfg  text eol=lf
*.ini  text eol=lf
*.toml text eol=lf
*.css  text eol=lf
*.html text eol=lf

# Binary files — no line ending conversion
*.pkl    binary
*.joblib binary
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary

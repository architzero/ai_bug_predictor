# Flask Secret Key (REQUIRED)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=your_secret_key_here

# GitHub OAuth Credentials (REQUIRED for authentication)
# Create OAuth app at: https://github.com/settings/developers
# Authorization callback URL: http://localhost:5000/auth/github/callback
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# GitHub Personal Access Token (REQUIRED for webhook PR comments)
# Create at: https://github.com/settings/tokens (scopes: repo, write:discussion)
GITHUB_TOKEN=your_github_pat_here

# GitHub Webhook Secret (REQUIRED for /webhook/github endpoint)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Then set the same value in your GitHub repo → Settings → Webhooks → Secret
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# Flask Environment
# Set to "production" to enable secure cookies (requires HTTPS)
FLASK_ENV=development
